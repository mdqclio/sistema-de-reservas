rules_version = '2';

// Reglas de Cloud Storage — bucket sistema-de-reservas-d9e54.firebasestorage.app
// Hoy la app guarda fotos de DNI como DataURL en RTDB (no usa Storage SDK), pero el
// bucket existe y por defecto puede quedar abierto. Esto lo cierra a usuarios autenticados.
// Como desplegar: Firebase Console -> Storage -> Reglas -> pegar -> Publicar.

service firebase.storage {
  match /b/{bucket}/o {
    // Denegar todo por defecto
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Documentos de huespedes (DNI, comprobantes): solo usuarios autenticados.
    // Limite de 10MB y solo imagenes/pdf.
    match /huespedes/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType == 'application/pdf');
    }
  }
}
